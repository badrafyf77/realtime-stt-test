HOST=0.0.0.0
PORT=8085

# RealtimeSTT uses faster-whisper, so the model must be in CTranslate2 format.
# This is the CT2 conversion of the original LoRA adapter:
# anaszil/whisper-large-v3-turbo-darija
STT_MODEL=anaszil/whisper-large-v3-turbo-darija-full-ct2
STT_REALTIME_MODEL=anaszil/whisper-large-v3-turbo-darija-full-ct2
STT_USE_MAIN_MODEL_FOR_REALTIME=true
STT_LANGUAGE=ar
STT_DEVICE=cuda
STT_COMPUTE_TYPE=float16
STT_DOWNLOAD_ROOT=./models/faster-whisper
HF_HOME=./models/huggingface
TORCH_HOME=./models/torch

# Optional but recommended for faster Hugging Face downloads/higher rate limits.
HF_TOKEN=

# Optional examples:
# STT_DEVICE=cpu
# STT_COMPUTE_TYPE=int8
# STT_DOWNLOAD_ROOT=./models
