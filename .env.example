HOST=0.0.0.0
PORT=8085

# Change this one line to switch models.
# Options:
#   aioxlabs/dvoice-darija
#   anaszil/whisper-large-v3-turbo-darija
STT_MODEL_ID=aioxlabs/dvoice-darija

STT_LANGUAGE=ar
STT_DEVICE=cuda
STT_COMPUTE_TYPE=float16

