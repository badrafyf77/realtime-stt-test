HOST=127.0.0.1
PORT=8085

# RealtimeSTT/faster-whisper model names can be sizes like small.en
# or Hugging Face CTranslate2 repos like Systran/faster-whisper-small.en.
STT_MODEL=small.en
STT_REALTIME_MODEL=small.en
STT_USE_MAIN_MODEL_FOR_REALTIME=true
STT_LANGUAGE=en

# Optional examples:
# STT_DEVICE=cpu
# STT_COMPUTE_TYPE=int8
# STT_DOWNLOAD_ROOT=./models
