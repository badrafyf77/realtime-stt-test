HOST=0.0.0.0
PORT=8085

# Change this one line to switch models.
# Options:
#   aioxlabs/dvoice-darija
#   anaszil/whisper-large-v3-turbo-darija
STT_MODEL_ID=aioxlabs/dvoice-darija

STT_LANGUAGE=ar
STT_DEVICE=cuda
STT_COMPUTE_TYPE=float16

# Optional examples:
# STT_DEVICE=cpu
# STT_COMPUTE_TYPE=int8

# SpeechBrain endpointing. Increase silence duration if transcripts are chopped.
# SPEECHBRAIN_POST_SPEECH_SILENCE_DURATION=1.2
# SPEECHBRAIN_MIN_RECORDING_DURATION=1.0
# SPEECHBRAIN_SPEECH_RMS_THRESHOLD=0.01
